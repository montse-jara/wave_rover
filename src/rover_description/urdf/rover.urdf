<?xml version="1.0"?>
<robot name="wave_rover">

  <link name="base_link"/>

  <link name="laser"/>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="-0.0381 0.00635 0.1524" rpy="0 0 0"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0381 0.00635 0.0300" rpy="0 0 0"/>
  </joint>

</robot>